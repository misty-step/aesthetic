{
  "name": "@misty-step/aesthetic",
  "version": "2.9.0",
  "description": "The Misty Step design system. One font size, nine ink-and-weight registers, a steerable accent, viewport screens instead of scrolling pages, motion as feedback only.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misty-step/aesthetic.git"
  },
  "homepage": "https://github.com/misty-step/aesthetic#readme",
  "keywords": [
    "design-system",
    "css",
    "tokens",
    "viewport"
  ],
  "main": "aesthetic.css",
  "style": "aesthetic.css",
  "exports": {
    ".": "./aesthetic.css",
    "./aesthetic.css": "./aesthetic.css",
    "./tokens.json": "./tokens.json",
    "./recipes/*": "./recipes/*",
    "./law": "./law/index.ts",
    "./law/*": "./law/*"
  },
  "files": [
    "aesthetic.css",
    "tokens.json",
    "recipes",
    "law",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:recipes": "node scripts/build-recipes.mjs",
    "build:registry": "node scripts/build-registry.mjs",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:feed": "node scripts/build-feed.mjs",
    "check": "prettier --check . && stylelint aesthetic.css site/site.css && node scripts/build-recipes.mjs --check && node scripts/build-tokens.mjs --check && node scripts/build-feed.mjs --check",
    "ci": "npm run check && npm test",
    "test": "playwright test",
    "release": "node scripts/release.mjs"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prettier": "3.8.4",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0"
  }
}
